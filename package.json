{
  "name": "demo-shop",
  "version": "0.0.1",
  "private": true,
  "description": "Single-merchant e-commerce MVP - Medusa backend, Nuxt 4 storefront, Vue 3 admin",
  "workspaces": [
    "backend",
    "storefront",
    "admin"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:backend": "cd backend && npm run dev",
    "dev:storefront": "cd storefront && npm run dev",
    "dev:admin": "cd admin && npm run dev",
    "build": "npm run build --workspaces --if-present",
    "clean": "rm -rf node_modules backend/node_modules storefront/node_modules admin/node_modules",
    "deploy": "cd backend && vercel --prod && cd ../storefront && vercel --prod && cd ../admin && vercel --prod",
    "deploy:preview": "vercel",
    "deploy:backend": "cd backend && vercel",
    "deploy:storefront": "cd storefront && vercel",
    "deploy:admin": "cd admin && vercel"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
